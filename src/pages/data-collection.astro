---
const version = "2026.0";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>wrong version</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- SCSS -->
    <style lang="scss">
        /* Some coloring like team colors and stuff*/
        $grey: #babfb7;
        $orange: #fe5000;
        $offblue: #02355b;
        $offwhite: #FAF9F6;
        $offBlack: #1D1C1B;

        /* Global styles */
        html, body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            font-family: "Inter", sans-serif;
            background-color: #00243e;
            color: $offwhite;
        }

        /* Page styles */
        .data-collection-page {
            display: flex;
            flex-direction: column;
            align-items: center;
            
            padding: 16px 12px 24px;
            width: 100%;
            max-width: 100vw;

            .title {
                display: flex;
                justify-content: space-between;
                align-items: center;
                width: 100%;
                max-width: 600px;
                margin-bottom: 24px;

                .app-name {
                    font-size: 1.5rem;
                    font-weight: 600;
                    color: $orange;
                }

                .version {
                    font-size: 1rem;
                    color: $grey;
                }

                .link-btn {
                    margin-left: auto;
                    background-color: $offblue;
                    color: $offwhite;
                    padding: 0.5rem 1rem;
                    border-radius: 6px;
                    text-decoration: none;
                    font-weight: 600;
                    transition: transform 0.2s ease, box-shadow 0.2s ease;

                    /* grow effect on hover */
                    &:hover {
                        transform: scale(1.05);
                        box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
                    }
                    /* andddd shrink effect on click */
                    &:active {
                        transform: scale(0.97);
                    }
                }
            }

            .data-collection-form {
                display: flex;
                flex-direction: column;
                align-items: center;
                width: 100%;
                max-width: 600px;

                label {
                    font-size: 1.1rem;
                    margin-bottom: 6px;
                    color: $offwhite;
                }

                input[type="number"] {
                    width: 100%;
                    max-width: 300px;
                    padding: 0.6rem;
                    margin-bottom: 16px;
                    border-radius: 6px;
                    border: 2px solid $grey;
                    background-color: $offBlack;
                    color: $offwhite;
                    font-size: 1rem;
                    text-align: center;
                    transition: all 0.3s ease;

                    &:focus {
                        outline: none;
                        box-shadow: 0 0 6px $orange;
                        border-color: $orange;
                    }
                }

                .team-select {
                    display: flex;
                    gap: 16px;
                    margin-top: 12px;

                    .team-btn {
                        padding: 0.6rem 1.2rem;
                        border-radius: 6px;
                        font-size: 1rem;
                        font-weight: 600;
                        border: 2px solid $grey;
                        background-color: transparent;
                        color: $grey;
                        cursor: pointer;
                        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
                        min-width: 140px;

                        &:hover {
                            transform: scale(1.05);
                            box-shadow: 0 0 8px rgba(255, 255, 255, 0.2);
                        }

                        &:active {
                            transform: scale(0.97);
                        }

                        &.selected {
                            color: #fff;
                            border: none;
                        }

                        /* change color based on selected team */
                        &.red.selected {
                            background-color: #aa3333;
                        }

                        &.blue.selected {
                            background-color: #2255cc;
                        }
                    }
                }
                .climb-select {
                    display: flex;
                    gap: 16px;
                    margin-top: 12px;

                    .climb-btn {
                        padding: 0.6rem 1.2rem;
                        border-radius: 6px;
                        font-size: 1rem;
                        font-weight: 600;
                        border: 2px solid $grey;
                        background-color: transparent;
                        color: $grey;
                        cursor: pointer;
                        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
                        min-width: 140px;

                        &:hover {
                            transform: scale(1.05);
                            box-shadow: 0 0 8px rgba(255, 255, 255, 0.2);
                        }

                        &:active {
                            transform: scale(0.97);
                        }

                        &.selected {
                            color: #fff;
                            border: none;
                        }

                        /* change color based on selected team */
                        &.climb.selected {
                            background-color: #14a900;
                        }

                        &.no-climb.selected {
                            background-color: #e20808;
                        }
                    }
                }
            }

            .movement-buttons {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
                margin-top: 24px;
                justify-items: center;

                .trench {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    background-color: rgba(0, 8, 125, 0.3);
                    gap: 8px;
                    padding: 12px;
                    border-radius: 12px;
                    box-shadow: 0 0 10px rgba(1, 24, 235, 0.4);
                    width: 140px;

                    .counter {
                        font-size: 2rem;
                        font-weight: 700;
                        color: $orange;
                        user-select: none;
                    }

                    .label {
                        font-size: 0.9rem;
                        color: $grey;
                        margin-top: 4px;
                    }

                    .trench-btn {
                        width: 48px;
                        height: 100%;
                        font-size: 1.4rem;
                        font-weight: 700;
                        border-radius: 8px;
                        border: 2px solid $grey;
                        background-color: transparent;
                        color: $offwhite;
                        cursor: pointer;
                        transition: transform 0.15s ease, box-shadow 0.15s ease;

                        &:hover {
                            transform: scale(1.05);
                            box-shadow: 0 0 8px rgba(255, 255, 255, 0.25);
                        }

                        &:active {
                            transform: scale(0.95);
                        }

                        &.plus {
                            border-color: #3cb371;
                            color: #3cb371;
                        }

                        &.minus {
                            border-color: #cc4444;
                            color: #cc4444;
                        }
                    }
                }
            }


            
        }


        
    </style>
</head>

<body>
    <main>
        <div class="data-collection-page">
            <div class="title">
                <div class="app-name">GearScout</div>
                <div class="version">v{version}</div>
                <a href="https://data.gearitforward.com" class="link-btn">ANALYTICS</a>
            </div>

            <form class="data-collection-form" id="data-collection-form">
                <label for="match-number">Match Number</label>
                <input type="number" id="match-number" name="match-number" oninput="if(this.value < 0) this.value = 0;" min="0" step="1"/>

                <label for="team-number">Team Number</label>
                <input type="number" id="team-number" name="team-number" oninput="if(this.value < 0) this.value = 0;" min="0" step="1"/>

                <div class="team-select">
                    <button type="button" class="team-btn red" onclick="selectAlliance('red')">RED ALLIANCE</button>
                    <button type="button" class="team-btn blue" onclick="selectAlliance('blue')">BLUE ALLIANCE</button>
                </div>
                

            </form>
            <div class="movement-buttons">
                <div class="trench">
                    <button type="button" class="trench-btn minus" data-trench="trench-1">−</button>
                    <div class="counter" id="trench-1-count">0</div>
                    <button type="button" class="trench-btn plus" data-trench="trench-1">+</button>
                    <div class="label">Trench 1</div>
                </div>

                <div class="trench">
                    <button type="button" class="trench-btn minus" data-trench="trench-2">−</button>
                    <div class="counter" id="trench-2-count">0</div>
                    <button type="button" class="trench-btn plus" data-trench="trench-2">+</button>
                    <div class="label">Trench 2</div>
                </div>

                <div class="trench">
                    <button type="button" class="trench-btn minus" data-trench="bump-1">−</button>
                    <div class="counter" id="bump-1-count">0</div>
                    <button type="button" class="trench-btn plus" data-trench="bump-1">+</button>
                    <div class="label">Bump 1</div>
                </div>

                <div class="trench">
                    <button type="button" class="trench-btn minus" data-trench="bump-2">−</button>
                    <div class="counter" id="bump-2-count">0</div>
                    <button type="button" class="trench-btn plus" data-trench="bump-2">+</button>
                    <div class="label">Bump 2</div>
                </div>

            </div>

            <form class="data-collection-form" id="data-collection-form">
                <div class="climb-select">
                    <button type="button" class="climb-btn climb" onclick="selectClimb('climb')">climb</button>
                    <button type="button" class="climb-btn no-climb" onclick="selectClimb('no-climb')">no climb</button>
                </div>
            </form>

        </div>
        


    </main>

    <script type="module">
        const counters = {};

        document.querySelectorAll(".trench-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                const key = btn.dataset.trench;
                const isPlus = btn.classList.contains("plus");

                if (!(key in counters)) {
                    counters[key] = 0;
                }

                counters[key] += isPlus ? 1 : -1;

                if (counters[key] < 0) {
                    counters[key] = 0;
                }

                document.getElementById(`${key}-count`).textContent = counters[key];
            });
        });


        // js to handle alliance selection
        const selectAlliance = (team) => {
            // remove selected class from all buttons
            document.querySelectorAll(".team-btn").forEach(btn => btn.classList.remove("selected"));
            // add selected class to cilcked button
            document.querySelector(`.team-btn.${team}`)?.classList.add("selected");

            // save the selected team 
            if (team === "red") {
                img.classList.add("rotate-red");
            } else if (team === "blue") {
                img.classList.add("rotate-blue");
            }
        };
        // tell it to be gobal
        window.selectAlliance = selectAlliance;


        // js to handle climb selection
        const selectClimb = (yep) => {
            // remove selected class from all buttons
            document.querySelectorAll(".climb-btn").forEach(btn => btn.classList.remove("selected"));
            // add selected class to cilcked button
            document.querySelector(`.climb-btn.${yep}`)?.classList.add("selected");

            // save the selected climb
            if (yep === "climb") {
                img.classList.add("climb");
            } else if (team === "no-climb") {
                img.classList.add("no-climb");
            }
        };
        // tell it to be gobal
        window.selectClimb = selectClimb;
    </script>
</body>
</html>