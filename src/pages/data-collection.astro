---
const version = import.meta.env.VITE_APP_VERSION || "2026.0";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>wrong version</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style lang="scss">
        $grey: #babfb7;
        $orange: #fe5000;
        $offblue: #02355b;
        $offwhite: #FAF9F6;
        $offBlack: #1D1C1B;

        html, body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            font-family: "Inter", sans-serif;
            background-color: #00243e;
            color: $offwhite;
        }

        .data-collection-page {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 16px 12px 24px;
            width: 100%;
            max-width: 100vw;

            .title {
                display: flex;
                justify-content: space-between;
                align-items: center;
                width: 100%;
                max-width: 600px;
                margin-bottom: 24px;

                .app-name {
                    font-size: 1.5rem;
                    font-weight: 600;
                    color: $orange;
                }

                .version {
                    font-size: 1rem;
                    color: $grey;
                }

                .link-btn {
                    margin-left: auto;
                    background-color: $offblue;
                    color: $offwhite;
                    padding: 0.5rem 1rem;
                    border-radius: 6px;
                    text-decoration: none;
                    font-weight: 600;
                    transition: transform 0.2s ease, box-shadow 0.2s ease;

                    &:hover {
                        transform: scale(1.05);
                        box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
                    }

                    &:active {
                        transform: scale(0.97);
                    }
                }
            }

            .data-collection-form {
                display: flex;
                flex-direction: column;
                align-items: center;
                width: 100%;
                max-width: 600px;

                label {
                    font-size: 1.1rem;
                    margin-bottom: 6px;
                    color: $offwhite;
                }

                input[type="number"] {
                    width: 100%;
                    max-width: 300px;
                    padding: 0.6rem;
                    margin-bottom: 16px;
                    border-radius: 6px;
                    border: 2px solid $grey;
                    background-color: $offBlack;
                    color: $offwhite;
                    font-size: 1rem;
                    text-align: center;
                    transition: all 0.3s ease;

                    &:focus {
                        outline: none;
                        box-shadow: 0 0 6px $orange;
                        border-color: $orange;
                    }
                }

                .team-select {
                    display: flex;
                    gap: 16px;
                    margin-top: 12px;

                    .team-btn {
                        padding: 0.6rem 1.2rem;
                        border-radius: 6px;
                        font-size: 1rem;
                        font-weight: 600;
                        border: 2px solid $grey;
                        background-color: transparent;
                        color: $grey;
                        cursor: pointer;
                        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
                        min-width: 140px;

                        &:hover {
                            transform: scale(1.05);
                            box-shadow: 0 0 8px rgba(255, 255, 255, 0.2);
                        }

                        &:active {
                            transform: scale(0.97);
                        }

                        &.selected {
                            color: #fff;
                            border: none;
                        }

                        &.red.selected {
                            background-color: #aa3333;
                        }

                        &.blue.selected {
                            background-color: #2255cc;
                        }
                    }
                }
            }

            
        }
        
        .frc-field-image {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 200px;
            img {
                width: 90%;
                max-width: 800px;
                height: auto;
            }
        }
    </style>
</head>

<body>
    <main>
        <div class="data-collection-page">
            <div class="title">
                <div class="app-name">GearScout</div>
                <div class="version">v{version}</div>
                <a href="https://data.gearitforward.com" class="link-btn">ANALYTICS</a>
            </div>

            <form class="data-collection-form" id="data-collection-form">
                <label for="match-number">Match Number</label>
                <input type="number" id="match-number" name="match-number" oninput="if(this.value < 0) this.value = 0;" min="0" step="1"/>

                <label for="team-number">Team Number</label>
                <input type="number" id="team-number" name="team-number" oninput="if(this.value < 0) this.value = 0;" min="0" step="1"/>

                <div class="team-select">
                    <button type="button" class="team-btn red" onclick="selectAlliance('red')">RED ALLIANCE</button>
                    <button type="button" class="team-btn blue" onclick="selectAlliance('blue')">BLUE ALLIANCE</button>
                </div>

            </form>

        </div>

        <div class="frc-field-image">
            <img src="frc-2026-field.svg" alt="FRC 2026 Field Diagram" style="transform: rotate(90deg);">
        </div>

    </main>

    <script type="module">
        const selectAlliance = (team) => {
            document.querySelectorAll(".team-btn").forEach(btn => btn.classList.remove("selected"));
            document.querySelector(`.team-btn.${team}`)?.classList.add("selected");
        };
        window.selectAlliance = selectAlliance;
    </script>
</body>
</html>